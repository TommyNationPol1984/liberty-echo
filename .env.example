# Database
DATABASE_URL=postgresql://user:password@localhost:5432/libertyecho

# Server
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=your-secret-here

# Python TTS Engine
TTS_ENGINE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5000

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard > Products
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_CREATOR_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# Vite client-side price IDs (safe to expose — price IDs are not secret)
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_...
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_...
VITE_STRIPE_PRICE_CREATOR_MONTHLY=price_...
VITE_STRIPE_PRICE_CREATOR_ANNUAL=price_...
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_ANNUAL=price_...
VITE_STRIPE_PRICE_SCALE_MONTHLY=price_...
VITE_STRIPE_PRICE_SCALE_ANNUAL=price_...
VITE_STRIPE_PRICE_BUSINESS_MONTHLY=price_...
VITE_STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# ElevenLabs — SERVER-SIDE ONLY. Never expose to the frontend.
ELEVENLABS_API_KEY=sk_...
